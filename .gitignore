access_token.txt
*.token

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Backtest output JSONs
results/
runs/

# LLMs
.claude/results/

# Quality gate sentinel (written by go-quality-review skill; local only)
.quality-gate/

# Session state checkpoint (transient; written during active sessions only)
workflows/.session-state.json
